Package: tidytree
Title: A Tidy Tool for Phylogenetic Tree Data Manipulation
Version: 0.4.8
Authors@R: c(
           person("Guangchuang", "Yu",   email = "guangchuangyu@gmail.com", role = c("aut", "cre", "cph"), comment = c(ORCID = "0000-0002-6485-8781")),
